<header
    class="py-10 px-4 container mx-auto text-xl flex flex-wrap md:flex-nowrap items-center justify-between bg-blue-100 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">
    <div class="flex items-center w-full md:2/3">
        <a class="font-black text-tertiary-dark" asp-area="" asp-controller="Home" asp-action="Index">Hotelzzz</a>
        <ul class="flex items-center ml-5">
            <li class="flex items-center">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Authentication" asp-action="Registration" asp-area=""
                        class="text-violet-950 hover:text-orange-300 dark:text-blue-300 dark:hover:text-white transition duration-300 ease-in-out">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5 " viewBox="0 0 512 512">
                            <path
                                d="M399 384.2C376.9 345.8 335.4 320 288 320l-64 0c-47.4 0-88.9 25.8-111 64.2c35.2 39.2 86.2 63.8 143 63.8s107.8-24.7 143-63.8zM0 256a256 256 0 1 1 512 0A256 256 0 1 1 0 256zm256 16a72 72 0 1 0 0-144 72 72 0 1 0 0 144z" />
                        </svg>
                    </a>
                }
                else
                {
                    @* Modal Trigger *@
                    <a onclick="showModal('loginModal')"
                        class="text-violet-950 hover:text-orange-300 dark:text-blue-300 dark:hover:text-white transition duration-300 ease-in-out">
                        <svg id="logInModalTrigger" xmlns="http://www.w3.org/2000/svg" fill="currentColor"
                            class="w-5 h-5 cursor-pointer " viewBox="0 0 512 512">
                            <path
                                d="M399 384.2C376.9 345.8 335.4 320 288 320l-64 0c-47.4 0-88.9 25.8-111 64.2c35.2 39.2 86.2 63.8 143 63.8s107.8-24.7 143-63.8zM0 256a256 256 0 1 1 512 0A256 256 0 1 1 0 256zm256 16a72 72 0 1 0 0-144 72 72 0 1 0 0 144z" />
                        </svg>
                    </a>
                }
            </li>
            <li class="ml-3 mt-1.5">
                <button id="darkModeToggle" class="cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" id="darkModeIcon" fill="currentColor"
                        viewBox="0 0 384 512">
                        <path
                            d="M223.5 32C100 32 0 132.3 0 256S100 480 223.5 480c60.6 0 115.5-24.2 155.8-63.4c5-4.9 6.3-12.5 3.1-18.7s-10.1-9.7-17-8.5c-9.8 1.7-19.8 2.6-30.1 2.6c-96.9 0-175.5-78.8-175.5-176c0-65.8 36-123.1 89.3-153.3c6.1-3.5 9.2-10.5 7.7-17.3s-7.3-11.9-14.3-12.5c-6.3-.5-12.6-.8-19-.8z" />
                    </svg>
                </button>
            </li>
        </ul>
    </div>
    <ul class="flex items-center justify-between w-full md:w-1/3 mt-4">
        <li class="hover:-translate-y-2 duration-500 transition-all">
            <a class="" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
        </li>
        <li class="hover:-translate-y-2 duration-500 transition-all">
            <a class="" asp-area="" asp-controller="Home" asp-action="Index">Rooms</a>
        </li>
        <li class="hover:-translate-y-2 duration-500 transition-all">
            <a class="" asp-area="" asp-controller="Home" asp-action="Index">Contact</a>
        </li>
    </ul>
</header>
@await Html.PartialAsync("Partials/LogInModal")
@await Html.PartialAsync("Partials/RegisterModal")


