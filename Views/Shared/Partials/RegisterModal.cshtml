@model HotelManagementSite.Models.ViewModels.RegisterModel
<div id="registerModal"
    class="fixed inset-0 z-50 flex hidden items-center justify-center overflow-y-auto bg-black bg-opacity-50">

    <div id="registerContent"
        class="-translate-y-10 w-full max-w-md scale-95 transform rounded-lg bg-gray-900 p-8 text-white opacity-0 shadow-lg transition-all duration-500">

        <div class="mb-6 flex items-start justify-between">
            <div class="space-y-1">
                <h1 class="text-3xl font-bold">Join Us</h1>
                <h2 class="text-xl">Create an Hotelzzz Account</h2>
                <p class="text-sm text-gray-300">Make great choice and feel the comfort.</p>
            </div>
            <button type="button" onclick="hideModal('registerModal')"
                class="flex h-8 w-8 items-center justify-center rounded-lg text-sm text-gray-400 hover:bg-gray-200 hover:text-gray-900 dark:hover:bg-gray-600 dark:hover:text-white">
                <svg class="h-3 w-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none"
                    viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
                </svg>
                <span class="sr-only">Close modal</span>
            </button>
        </div>

        <form asp-controller="Account" asp-action="Register" method="post">
            <div class="mb-4">
                <input required asp-for="UserName" type="text" placeholder="Your Name" class="w-full rounded bg-gray-700 p-3 text-white" />
            </div>
            <div class="mb-4">
                <input required asp-for="Email" type="email" placeholder="Email" class="w-full rounded bg-gray-700 p-3 text-white" />
            </div>
            <div class="mb-4">
                <input required asp-for="Password" type="password" placeholder="Password" class="w-full rounded bg-gray-700 p-3 text-white" />
            </div>
            <div class="mb-4">
                <input required asp-for="ConfirmPassword" type="Password" placeholder="Confirm Password" class="w-full rounded bg-gray-700 p-3 text-white" />
            </div>
            <div class="mb-4 flex items-center">
                <input type="checkbox" id="terms" class="mr-2" />
                <label for="terms" class="text-sm">
                    I agree to HackerRank's <a href="#" class="text-blue-500">Terms of Service</a> and <a href="#"
                        class="text-blue-500">Privacy Policy</a>.
                </label>
            </div>
            <button type="submit" class="w-full rounded bg-blue-600 p-3 font-bold text-white">Sign up</button>
        </form>

        <div class="my-6 flex items-center">
            <hr class="flex-grow border-gray-600">
            <span class="mx-4">or</span>
            <hr class="flex-grow border-gray-600">
        </div>

        <div class="mb-6 flex justify-center">
            <button class="flex items-center rounded bg-white p-3 text-gray-900">
                <img src="https://img.icons8.com/color/48/000000/google-logo.png" alt="Google" class="mr-2 h-6 w-6" />
                Continue with Google
            </button>
        </div>

        <div class="mb-6 flex justify-around">
            <button class="flex items-center rounded bg-blue-700 p-3">
                <img src="https://img.icons8.com/ios-filled/50/ffffff/linkedin.png" alt="LinkedIn"
                    class="mr-2 h-6 w-6" />
                LinkedIn
            </button>
            <button class="flex items-center rounded bg-gray-900 p-3">
                <img src="https://img.icons8.com/ios-filled/50/ffffff/github.png" alt="GitHub" class="mr-2 h-6 w-6" />
                GitHub
            </button>
            <button class="flex items-center rounded bg-blue-600 p-3">
                <img src="https://img.icons8.com/ios-filled/50/ffffff/facebook.png" alt="Facebook"
                    class="mr-2 h-6 w-6" />
                Facebook
            </button>
        </div>

        <p class="text-center">
            Already have an account? <a class="cursor-pointer text-blue-500"
                onclick="toggleModals(`loginModal`,`registerModal`)">Log in</a>
        </p>
    </div>
</div>

